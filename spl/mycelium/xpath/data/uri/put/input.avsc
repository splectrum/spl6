{
  "type": "record",
  "name": "put_input",
  "namespace": "spl.mycelium.xpath.data.uri.put",
  "doc": "Input shape for one xpath.data.uri.put invocation.",
  "fields": [
    {
      "name": "uri",
      "type": "string",
      "position": "key",
      "doc": "Node URI relative to local root. Travels as the stream record key. Metadata paths return an error (data lens)."
    },
    {
      "name": "content",
      "type": "bytes",
      "doc": "Content to write as node value."
    }
  ]
}
