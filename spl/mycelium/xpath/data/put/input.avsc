{
  "type": "record",
  "name": "put_input",
  "namespace": "spl.mycelium.xpath.data.put",
  "doc": "Input shape for one xpath.data.put invocation.",
  "fields": [
    {
      "name": "uri",
      "type": "string",
      "position": "key",
      "doc": "Node URI relative to local root. Metadata paths return an error (data lens)."
    },
    {
      "name": "content",
      "type": "bytes",
      "doc": "Content to write. Encoding respects the node's resolved type."
    }
  ]
}
